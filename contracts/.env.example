# Hardhat / deploy — copy to contracts/.env
# NEVER commit contracts/.env (contains DEPLOYER_PRIVATE_KEY)

# Required for robinhoodTestnet / sepolia / mainnet deploys
DEPLOYER_PRIVATE_KEY=

# Public RPCs (no secrets)
RH_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
RH_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
RPC_URL=https://rpc.testnet.chain.robinhood.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional explorer verification
ETHERSCAN_API_KEY=
