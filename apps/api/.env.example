# SilentTransfer API — copy to apps/api/.env and fill values.
# NEVER commit a real .env file.

# Database (SQLite for local; Postgres for shared environments)
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/silenttransfer

API_PORT=8001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# Auth — generate a long random string for JWT_SECRET
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

SIWE_DOMAIN=localhost:3000
SIWE_URI=http://localhost:3000

# Environment: demo | testnet | mainnet
ENVIRONMENT=testnet
DEMO_MODE=false
ALLOW_OPERATOR_LOGIN=true
SIMULATE_SETTLEMENT=true

# Robinhood Chain Testnet (example)
CHAIN_ID=46630
NETWORK_NAME=Robinhood Chain Testnet
RPC_URL=https://rpc.testnet.chain.robinhood.com

# Deployed contract addresses (public; safe to share)
REGISTRY_CONTRACT_ADDRESS=
MESSENGER_CONTRACT_ADDRESS=
PAYMASTER_CONTRACT_ADDRESS=
SILENT_TOKEN_ADDRESS=

PROTOCOL_FEE_BPS=0

# Optional live settlement (do not commit real keys)
BUNDLER_URL=
PAYMASTER_URL=
RELAYER_PRIVATE_KEY=

RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
