# SilentTransfer Web — copy to apps/web/.env.local
# NEVER commit .env.local

NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=/docs

# Environment: demo | testnet | mainnet
NEXT_PUBLIC_ENVIRONMENT=testnet
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_NETWORK_NAME=Robinhood Chain Testnet
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Public contract addresses (safe to expose in the browser)
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_MESSENGER_ADDRESS=
NEXT_PUBLIC_PAYMASTER_ADDRESS=
NEXT_PUBLIC_SILENT_ADDRESS=

NEXT_PUBLIC_PROTOCOL_FEE_BPS=0
NEXT_PUBLIC_SIWE_DOMAIN=localhost:3000
NEXT_PUBLIC_SIWE_URI=http://localhost:3000

# WalletConnect Cloud project id (https://cloud.walletconnect.com) — required for WC QR
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
